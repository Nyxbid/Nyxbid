# ---- Solana RPC ----
#
# OrbitFlare (https://orbitflare.com) — region-pinned RPC + WS with
# API-key auth. Free tier: 10 req/s, 1 tx/s. Bumps to higher tiers
# for production volume.
#
# AMS (Amsterdam) — closest to most EU hosts:
#   SOLANA_RPC_URL=https://ams.rpc.orbitflare.com?api_key=ORBIT-XXXXXX-XXXXXX-XXXXXX
#   SOLANA_WS_URL=wss://ams.rpc.orbitflare.com?api_key=ORBIT-XXXXXX-XXXXXX-XXXXXX
# FRA (Frankfurt):
#   SOLANA_RPC_URL=https://fra.rpc.orbitflare.com?api_key=ORBIT-XXXXXX-XXXXXX-XXXXXX
#
# Always use HTTPS / WSS. The dashboard shows http:// — that's the
# raw form. Browsers block mixed-content WS from HTTPS pages, so the
# https/wss form is mandatory in production.
#
# Devnet default (no OrbitFlare key needed):
SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional override. Default = SOLANA_RPC_URL with https->wss; the
# api_key query string is preserved by the rewrite.
# SOLANA_WS_URL=wss://api.devnet.solana.com

SOLANA_KEYPAIR_PATH=~/.config/solana/id.json
NYXBID_PROGRAM_ID=nyxkGtm8x7GMdTWKyy5TKa72pgsebrECrchPDuRSrEQ
# Devnet USDC mint. For mainnet, use the real circle mint:
#   EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NYXBID_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
RUST_LOG=info

# ---- public surface ----
PUBLIC_BASE_URL=http://localhost:8080

# ---- compose port mapping ----
SERVER_PORT=8080
CLIENT_PORT=3000

# ---- next.js client ----
NEXT_PUBLIC_API_URL=http://localhost:8080
# Browser wallet RPC. Use OrbitFlare in prod — the public devnet
# faucet is heavily rate-limited and not suitable for live users.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
