# ---- Solana RPC ----
SOLANA_RPC_URL=https://api.devnet.solana.com
# WS auto-derives from SOLANA_RPC_URL (https -> wss). Override only
# if you need a different WS endpoint than HTTP.
# SOLANA_WS_URL=wss://api.devnet.solana.com

SOLANA_KEYPAIR_PATH=~/.config/solana/id.json
NYXBID_PROGRAM_ID=nyxkGtm8x7GMdTWKyy5TKa72pgsebrECrchPDuRSrEQ
# Devnet USDC faucet mint.
NYXBID_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
RUST_LOG=info

# ---- public surface ----
PUBLIC_BASE_URL=http://localhost:8080

# ---- compose port mapping ----
SERVER_PORT=8080
CLIENT_PORT=3000

# ---- next.js client ----
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
